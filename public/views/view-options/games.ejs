<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Games - isItRunnable AI</title>
    
    <%- include('../partials/seo', {
        title: 'Discover Games — isItRunnable AI',
        description: 'Browse trending, popular, top-rated, and upcoming games to check their hardware requirements and compatibility.',
        keywords: 'games, hardware requirements, trending games, top-rated games, isItRunnable AI',
        canonical: 'https://is-it-runnable-ai.vercel.app/games'
    }) %>

    <link rel="stylesheet" href="/views/css/style.css">
    <link rel="stylesheet" href="/views/css/games.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <canvas id="geometricBackground" class="geometric-canvas"></canvas>

    <%- include('../partials/navbar') %>

    <main class="games-container">
        <!-- Card 1: Overview -->
        <div class="glass-card overview-card">
            <div class="overview-header">
                <h1>Overview</h1>
                <p>Browse our AI-curated library and instantly check if your system can handle it. Our smart platform analyzes technical specifications to provide accurate performance reports.</p>
            </div>
            
            <div class="overview-stats-grid">
                <div class="stat-square-card">
                    <i class="fa-solid fa-gamepad"></i>
                    <span><strong>500K+</strong> Games Tracked</span>
                </div>
                <div class="stat-square-card">
                    <i class="fa-solid fa-bolt"></i>
                    <span><strong>Instant</strong> AI Analysis</span>
                </div>
                <div class="stat-square-card">
                    <i class="fa-solid fa-layer-group"></i>
                    <span><strong>4</strong> Categories</span>
                </div>
                <div class="stat-square-card">
                    <i class="fa-solid fa-right-left"></i>
                    <span><strong>Track</strong> requirements</span>
                </div>
                <div class="stat-square-card">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span><strong>Free</strong> to Check</span>
                </div>
            </div>
        </div>

        <!-- Card 2: Instructions -->
        <div class="glass-card instructions-card">
            <div class="instructions-header">
                <h1>Instructions</h1>
                <p>Follow these simple steps to check your hardware compatibility and get detailed AI performance reports.</p>
            </div>
            
            <div class="instructions-grid">
                <div class="instruction-item">
                    <div class="instruction-number">1</div>
                    <div class="instruction-content">
                        <strong>Find a Game</strong>
                        <span>Browse or search the library</span>
                    </div>
                </div>
                <div class="instruction-item">
                    <div class="instruction-number">2</div>
                    <div class="instruction-content">
                        <strong>Click "Can I Run It?"</strong>
                        <span>Your specs are pre-filled</span>
                    </div>
                </div>
                <div class="instruction-item">
                    <div class="instruction-number">3</div>
                    <div class="instruction-content">
                        <strong>Get AI Report</strong>
                        <span>FPS, settings & bottlenecks</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 3: Games Content -->
        <div class="glass-card games-list-card">
            <!-- Combined Search & Tabs -->
            <div class="controls-row">
                <div class="search-section">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" id="gameSearch" placeholder="Search for a game..." autocomplete="off">
                    </div>
                </div>

                <div class="category-tabs">
                    <button class="tab-btn active" data-category="trending">
                        <i class="fa-solid fa-fire"></i> Trending
                    </button>
                    <button class="tab-btn" data-category="popular">
                        <i class="fa-solid fa-heart"></i> Popular
                    </button>
                    <button class="tab-btn" data-category="top-rated">
                        <i class="fa-solid fa-star"></i> Top Rated
                    </button>
                    <button class="tab-btn" data-category="release">
                        <i class="fa-solid fa-calendar-days"></i> New Releases
                    </button>
                </div>
            </div>

            <!-- Results Info Bar -->
            <div class="results-info-bar" id="resultsInfoBar">
                <span id="resultsCount"><i class="fa-solid fa-spinner fa-spin"></i> Loading games...</span>
                <span class="results-category-label" id="resultsCategoryLabel">Trending</span>
            </div>

            <!-- Games Grid -->
            <div id="gamesGrid" class="games-grid"></div>

            <!-- Pagination -->
            <div id="paginationContainer" class="pagination-container"></div>
        </div>
        <!-- Card 4: Genres -->
        <div class="glass-card genres-section-card">
            <div class="genres-header">
                <h1>Games by Genre</h1>
                <p>Browse our curated library by genre to find the perfect experience for your hardware.</p>
            </div>
            <div class="genres-grid" id="genresGrid">
                <!-- Genres will be loaded here -->
            </div>      
        </div>
        <!--Gaming Resources-->
        <div class="glass-card gaming-resources-card">
            <div class="gaming-resources-header">
                <h1>Gaming Resources</h1>
                <p>Browse our curated library by genre to find the perfect experience for your hardware.</p>
            </div>
            <div class="gaming-resources-grid" id="gamingResourcesGrid">
                <!-- Gaming Resources will be loaded here -->
            </div>      
        </div>
        <!-- Additional features-->
         <div class="glass-card additional-features-card">
            <div class="additional-features-header">
                <h1>Additional Features</h1>
                <p>Here are some of the additional features that we offer:</p>
            </div>
            <div class="additional-features-grid" id="additionalFeaturesGrid">
                <!-- Additional Features will be loaded here -->
            </div>      
        </div>
    </main>

    <script src="/views/js/plexus.js"></script>
    <script src="/views/js/games.js"></script>
    <script>
        const genresList = [
            { name: 'Action', icon: 'fa-solid fa-gun' },
            { name: 'Adventure', icon: 'fa-solid fa-map' },
            { name: 'RPG', icon: 'fa-solid fa-shield-halved' },
            { name: 'Strategy', icon: 'fa-solid fa-chess' },
            { name: 'Shooter', icon: 'fa-solid fa-crosshairs' },
            { name: 'Racing', icon: 'fa-solid fa-car' },
            { name: 'Sports', icon: 'fa-solid fa-futbol' },
            { name: 'Simulation', icon: 'fa-solid fa-vr-cardboard' },
            { name: 'Indie', icon: 'fa-solid fa-lightbulb' },
            { name: 'Puzzle', icon: 'fa-solid fa-puzzle-piece' },
            { name: 'Arcade', icon: 'fa-solid fa-gamepad' },
            { name: 'Platformer', icon: 'fa-solid fa-mountain' },
            { name: 'Fighting', icon: 'fa-solid fa-hand-fist' },
            { name: 'Brawler', icon: 'fa-solid fa-robot' },
            { name:'Tactical', icon:'fa-solid fa-chess'}
            
        ];
        const gamingResources = [
            { name: 'Steam', icon: 'fa-brands fa-steam', url: 'https://store.steampowered.com/' },
            { name: 'Epic Games', icon: 'fa-solid fa-bolt', url: 'https://www.epicgames.com/' },
            { name: 'GOG', icon: 'fa-solid fa-ghost', url: 'https://www.gog.com/' },
            { name: 'Humble Bundle', icon: 'fa-solid fa-box-open', url: 'https://www.humblebundle.com/' },
            { name: 'itch.io', icon: 'fa-brands fa-itch-io', url: 'https://itch.io/' },
            { name: 'PlayStation', icon: 'fa-brands fa-playstation', url: 'https://store.playstation.com/' },
            { name: 'Xbox', icon: 'fa-brands fa-xbox', url: 'https://www.xbox.com/' },
            { name: 'Nintendo', icon: 'fa-solid fa-n', url: 'https://www.nintendo.com/' },
            { name: 'Microsoft', icon: 'fa-brands fa-microsoft', url: 'https://www.microsoft.com/en-us/store/games' },
            { name: 'Amazon Games', icon: 'fa-brands fa-amazon', url: 'https://www.amazon.com/gaming' },
            { name: 'GameStop', icon: 'fa-solid fa-gamepad', url: 'https://www.gamestop.com/' },
            { name: 'Newegg', icon: 'fa-solid fa-microchip', url: 'https://www.newegg.com/' },
            { name: 'Best Buy', icon: 'fa-solid fa-tag', url: 'https://www.bestbuy.com/' }
        ];
        const additionalFeatures = [
            { name: 'Check Hardware Compatibility', description:'Check if your hardware is compatible with games', icon: 'fa-solid fa-microchip', url: '/check' },
            { name: 'Performance test', description:'Test your hardware performance', icon: 'fa-solid fa-chart-line', url: '/performance' },
            { name: 'Game news', description:'Get latest game news and updates', icon: 'fa-solid fa-newspaper', url: '/news'},
            { name: 'Game reviews', description:'Get game reviews from critics and users', icon: 'fa-solid fa-star', url: 'https://www.metacritic.com/browse/game/pc/'}
        ];
        function loadGenres() {
            const grid = document.getElementById('genresGrid');
            if (!grid) return;
            
            grid.innerHTML = genresList.map(genre => `
                <div class="genre-item" onclick="filterByGenre('${genre.name.toLowerCase()}')">
                    <div class="genre-icon-wrapper">
                        <i class="${genre.icon}"></i>
                    </div>
                    <span>${genre.name}</span>
                </div>
            `).join('');
        }

        function loadGamingResources() {
            const grid = document.getElementById('gamingResourcesGrid');
            if (!grid) return;

            grid.innerHTML = gamingResources.map(res => `
                <a href="${res.url}" target="_blank" rel="noopener noreferrer" class="resource-item">
                    <div class="resource-icon-wrapper">
                        <i class="${res.icon}"></i>
                    </div>
                    <span>${res.name}</span>
                </a>
            `).join('');
        }

        function loadAdditionalFeatures() {
            const grid = document.getElementById('additionalFeaturesGrid');
            if (!grid) return;

            grid.innerHTML = additionalFeatures.map(feature => `
                <a href="${feature.url}" class="feature-item">
                    <div class="feature-icon-wrapper">
                        <i class="${feature.icon}"></i>
                    </div>
                    <div class="feature-text">
                        <strong>${feature.name}</strong>
                        <p>${feature.description}</p>
                    </div>
                    <div class="feature-arrow">
                        <i class="fa-solid fa-chevron-right"></i>
                    </div>
                </a>
            `).join('');
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadGenres();
            loadGamingResources();
            loadAdditionalFeatures();
        });

        function filterByGenre(genreName) {
            console.log("Filtering by:", genreName);
            // Integration with games.js
        }
    </script>
</body>
</html>
