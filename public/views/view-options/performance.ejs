<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hardware Performance Audit - isItRunnable AI</title>
    <link rel="stylesheet" href="/views/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    
    <!-- Geometric Background Canvas -->
    <canvas id="geometricBackground" class="geometric-canvas"></canvas>

    <%- include('../partials/navbar') %>

    <main class="check-container">
        <div class="glass-card form-wrapper">
            <h2 class="form-title">Performance Audit</h2>
            <p class="form-subtitle">Enter your specifications to get a deep technical analysis of your system's standing.</p>
            
            <form id="performanceForm" class="hardware-form">
                <!-- Device Type Selection -->
                <div class="form-group">
                    <label>Device Type</label>
                    <div class="radio-group">
                        <label class="radio-card">
                            <input type="radio" name="deviceType" value="pc" checked>
                            <span class="radio-content">
                                <i class="fas fa-desktop"></i>
                                Desktop PC
                            </span>
                        </label>
                        <label class="radio-card">
                            <input type="radio" name="deviceType" value="laptop">
                            <span class="radio-content">
                                <i class="fas fa-laptop"></i>
                                Laptop
                            </span>
                        </label>
                    </div>
                </div>

                <!-- Dynamic Fields -->
                <div id="dynamicFields" class="dynamic-fields">
                    <!-- Laptop-only Field (Hidden by default) -->
                    <div id="laptopOnlyFields" class="form-group hidden">
                        <label for="laptopModel">Laptop Brand & Model</label>
                        <input type="text" id="laptopModel" name="laptopModel" placeholder="e.g. Lenovo Legion 5 or ASUS ROG Zephyrus">
                    </div>

                    <!-- Common Hardware Fields -->
                    <div id="commonFields" class="device-fields">
                        <div class="form-group">
                            <label for="cpu">Processor (CPU)</label>
                            <input type="text" id="cpu" name="cpu" placeholder="e.g. Intel Core i5-12400F" required>
                        </div>
                        <div class="form-group">
                            <label for="gpu">Graphics Card (GPU)</label>
                            <input type="text" id="gpu" name="gpu" placeholder="e.g. NVIDIA RTX 3060" required>
                        </div>
                        <div class="form-group">
                            <label for="ram">RAM Capacity (GB)</label>
                            <select id="ram" name="ram" required>
                                <option value="" disabled selected>Select RAM</option>
                                <option value="4">4 GB</option>
                                <option value="8">8 GB</option>
                                <option value="16">16 GB</option>
                                <option value="32">32 GB</option>
                                <option value="64">64+ GB</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="windowVersion">Windows Version</label>
                            <select id="windowVersion" name="windowVersion" required>
                                <option value="" disabled selected>Select Windows version</option>
                                <option value="Windows 10 32-bit">Windows 10 32-bit</option>
                                <option value="Windows 10 64-bit">Windows 10 64-bit</option>
                                <option value="Windows 11 64-bit">Windows 11 64-bit</option>
                                <option value="Windows 8 32-bit">Windows 8 32-bit</option>
                                <option value="Windows 8 64-bit">Windows 8 64-bit</option>
                                <option value="Windows 7 32-bit">Windows 7 32-bit</option>
                                <option value="Windows 7 64-bit">Windows 7 64-bit</option>
                                <option value="Windows Vista 32-bit">Windows Vista 32-bit</option>
                                <option value="Windows Vista 64-bit">Windows Vista 64-bit</option>
                                <option value="Windows XP 32-bit">Windows XP 32-bit</option>
                                <option value="Windows XP 64-bit">Windows XP 64-bit</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="diskType">Storage Type</label>
                            <select id="diskType" name="diskType" required>
                                <option value="" disabled selected>Select Type</option>
                                <option value="HDD">HDD</option>
                                <option value="SSD">SSD</option>
                            </select>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-primary w-100 mt-4" id="submitBtn">
                    Start Performance Audit
                </button>
            </form>
        </div>
    </main>

    <script src="/views/js/toast.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const deviceRadios = document.querySelectorAll('input[name="deviceType"]');
            const laptopOnlyFields = document.getElementById('laptopOnlyFields');
            const submitBtn = document.getElementById('submitBtn');

            deviceRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if (e.target.value === 'laptop') {
                        laptopOnlyFields.classList.remove('hidden');
                    } else {
                        laptopOnlyFields.classList.add('hidden');
                    }
                });
            });

            document.getElementById('performanceForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Analyzing...';
                submitBtn.disabled = true;

                const formData = new FormData(e.target);
                const data = {};
                formData.forEach((value, key) => { data[key] = value; });

                try {
                    const response = await fetch(`/performance/analyze?data=${encodeURIComponent(JSON.stringify(data))}`);
                    
                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.details || errorData.error || `Error Status: ${response.status}`);
                    }

                    const html = await response.text();
                    document.documentElement.innerHTML = html;
                } catch (error) {
                    console.error('Analysis error:', error);
                    Toast.show({ type: 'error', title: 'Analysis Failed', message: error.message });

                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            });
        });
    </script>
    <div class="toast-container" id="toastContainer"></div>

    <script src="/views/js/plexus.js"></script>

</body>
</html>
