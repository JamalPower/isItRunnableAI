<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>isItRunnable AI - Smart Hardware Compatibility</title>
    <meta name="description" content="Determine hardware compatibility with demanding games and programs using our AI API.">
    <link rel="stylesheet" href="/views/css/style.css">
</head>
<body>
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    
    <!-- Geometric Background Canvas -->
    <canvas id="geometricBackground" class="geometric-canvas"></canvas>

    <%- include('partials/navbar') %>

    <main class="hero">
        <h1 class="hero-title">Will It Run? Find Out Now.</h1>
        <p class="hero-description">
            A smart platform designed to help users—especially those with mid-range and low-end computers—determine their hardware compatibility with demanding games and programs before downloading them. Instead of relying on dry numbers, the project uses AI to analyze technical specifications and provide an accurate, predictive, and human-centered performance report.
        </p>
        <button id="startCheckingBtn" class="btn-primary">
            Start Checking Now
        </button>
    </main>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // Geometric Background Animation
        const canvas = document.getElementById('geometricBackground');
        const ctx = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        class GeometricShape {
            constructor(x, y, size, type, vx, vy, color) {
                this.x = x;
                this.y = y;
                this.originX = x;
                this.originY = y;
                this.size = size;
                this.type = type;
                this.vx = vx;
                this.vy = vy;
                this.color = color;
                this.rotation = Math.random() * Math.PI * 2;
                this.rotationSpeed = (Math.random() - 0.5) * 0.01;
                this.moveRange = 80; // Shapes only move within 80px of origin
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.rotation += this.rotationSpeed;

                // Keep shapes contained within their movement range
                const distX = Math.abs(this.x - this.originX);
                const distY = Math.abs(this.y - this.originY);

                if (distX > this.moveRange) {
                    this.vx *= -1;
                    this.x = this.originX + (this.moveRange * Math.sign(this.x - this.originX));
                }
                if (distY > this.moveRange) {
                    this.vy *= -1;
                    this.y = this.originY + (this.moveRange * Math.sign(this.y - this.originY));
                }
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.rotation);
                ctx.fillStyle = this.color;
                ctx.strokeStyle = this.color;
                ctx.lineWidth = 1;

                if (this.type === 'triangle') {
                    ctx.beginPath();
                    ctx.moveTo(0, -this.size);
                    ctx.lineTo(this.size, this.size);
                    ctx.lineTo(-this.size, this.size);
                    ctx.closePath();
                    ctx.fill();
                } else if (this.type === 'square') {
                    ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
                } else if (this.type === 'circle') {
                    ctx.beginPath();
                    ctx.arc(0, 0, this.size / 2, 0, Math.PI * 2);
                    ctx.fill();
                }

                ctx.restore();
            }
        }

        // Create geometric shapes
        const shapes = [];
        const colors = [
            'rgba(59, 130, 246, 0.08)',  // Blue
            'rgba(139, 92, 246, 0.08)',  // Purple
            'rgba(16, 185, 129, 0.08)',  // Green
            'rgba(59, 130, 246, 0.06)',  // Blue (lighter)
            'rgba(139, 92, 246, 0.06)',  // Purple (lighter)
        ];
        const types = ['triangle', 'square', 'circle'];

        for (let i = 0; i < 12; i++) {
            const x = Math.random() * canvas.width;
            const y = Math.random() * canvas.height;
            const size = Math.random() * 60 + 30;
            const type = types[Math.floor(Math.random() * types.length)];
            const vx = (Math.random() - 0.5) * 0.15;
            const vy = (Math.random() - 0.5) * 0.15;
            const color = colors[Math.floor(Math.random() * colors.length)];

            shapes.push(new GeometricShape(x, y, size, type, vx, vy, color));
        }

        // Animation loop
        function animate() {
            ctx.fillStyle = 'rgba(255, 255, 255, 0.02)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            shapes.forEach(shape => {
                shape.update();
                shape.draw();
            });

            requestAnimationFrame(animate);
        }

        animate();
    </script>

    <script>
         const toastContainer = document.getElementById('toastContainer');
            
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon">✓</div>
                <div style="text-align: left;">
                    <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.2rem;">Checking Started</strong>
                    <div style="font-size: 0.9rem; color: #cbd5e1;">We are analyzing your hardware specifications...</div>
                </div>
            `;
            
            toastContainer.appendChild(toast);
        document.getElementById('startCheckingBtn').addEventListener('click', function() {
            window.location.href = '/check';
            toast.classList.add('show');

            // Remove toast after 4 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 4000);
        });
    </script>
</body>
</html>